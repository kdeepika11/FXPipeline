from pyspark.sql import functions as F
from pyspark.sql.types import StructType, StructField, StringType, DoubleType, MapType
import hashlib

dbutils.widgets.text("p_run_date", "")
dbutils.widgets.text("p_base_ccy", "USD")
run_date = dbutils.widgets.get("p_run_date")
base_ccy = dbutils.widgets.get("p_base_ccy").upper()

if not run_date:
    raise ValueError("p_run_date is required (yyyy-MM-dd)")

bronze_folder = (f"abfss://bronze@stassetlakehouse.dfs.core.windows.net/"
                 f"fx_rates/base={base_ccy}/run_date={run_date}/")
raw_path = bronze_folder + "*.json"
schema = StructType([
    StructField("amount", DoubleType(), True),
    StructField("base", StringType(), True),
    StructField("date", StringType(), True),
    StructField("rates", MapType(StringType(), DoubleType()), True)
])

raw_df = spark.read.schema(schema).json(raw_path)

df = (raw_df
    .select(
        F.to_date("date").alias("rate_date"),
        F.upper("base").alias("base_ccy"),
        F.col("rates").alias("rates_map")
    )
    .select("rate_date", "base_ccy", F.explode("rates_map").alias("quote_ccy", "fx_rate"))
    .withColumn("quote_ccy", F.upper("quote_ccy"))
    .withColumn("fx_rate", F.col("fx_rate").cast("double"))
)


# Ensure base->base exists (USD->USD = 1.0)
base_self = (df.select("rate_date", "base_ccy").distinct()
             .withColumn("quote_ccy", F.col("base_ccy"))
             .withColumn("fx_rate", F.lit(1.0)))

df = (df.unionByName(base_self)
        .dropDuplicates(["rate_date", "base_ccy", "quote_ccy"])
        .withColumn("ingest_ts", F.current_timestamp())
        .withColumn("source_file", F.input_file_name())
        .withColumn("run_date", F.to_date(F.lit(run_date)))
     )

# Schema registry (optional but nice)
schema_json = df.schema.json()
schema_hash = hashlib.sha256(schema_json.encode("utf-8")).hexdigest()

spark.sql("""
CREATE TABLE IF NOT EXISTS meta.schemas (
  source_name STRING,
  object_name STRING,
  schema_hash STRING,
  schema_json STRING,
  first_seen_ts TIMESTAMP,
  last_seen_ts TIMESTAMP,
  is_current BOOLEAN
) USING DELTA
""")

source_name, object_name = "fx_rates", "frankfurter"
spark.sql(f"""
UPDATE meta.schemas
SET is_current = false, last_seen_ts = current_timestamp()
WHERE source_name='{source_name}' AND object_name='{object_name}' AND is_current=true
  AND schema_hash <> '{schema_hash}'
""")

spark.sql(f"""
INSERT INTO meta.schemas
SELECT '{source_name}', '{object_name}', '{schema_hash}', '{schema_json.replace("'", "''")}',
       current_timestamp(), current_timestamp(), true
WHERE NOT EXISTS (
  SELECT 1 FROM meta.schemas
  WHERE source_name='{source_name}' AND object_name='{object_name}' AND schema_hash='{schema_hash}'
)
""")

# Create silver table if needed
spark.sql("""
CREATE TABLE IF NOT EXISTS silver.fx_rates (
  rate_date DATE,
  base_ccy STRING,
  quote_ccy STRING,
  fx_rate DOUBLE,
  ingest_ts TIMESTAMP,
  source_file STRING,
  run_date DATE
) USING DELTA
PARTITIONED BY (rate_date)
""")

(df.write.format("delta")
   .mode("append")
   .saveAsTable("silver.fx_rates"))

display(df.orderBy("rate_date","quote_ccy"))
