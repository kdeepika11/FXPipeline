{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-asset-services"
		},
		"ADLinkedService_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'ADLinkedService'"
		},
		"ls_adb_assetlakehouse_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'ls_adb_assetlakehouse'"
		},
		"ADLinkedService_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0302-013530-jo0pxc4i"
		},
		"ls_adls_stassetlakehouse_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stassetlakehouse.dfs.core.windows.net/"
		},
		"ls_http_frankfurter_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://api.frankfurter.dev/v1/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-asset-services_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ADLinkedService_accessToken": {
						"value": "[parameters('ADLinkedService_accessToken')]"
					},
					"ls_adb_assetlakehouse_accessToken": {
						"value": "[parameters('ls_adb_assetlakehouse_accessToken')]"
					},
					"ADLinkedService_properties_typeProperties_existingClusterId": {
						"value": "[parameters('ADLinkedService_properties_typeProperties_existingClusterId')]"
					},
					"ls_adls_stassetlakehouse_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_stassetlakehouse_properties_typeProperties_url')]"
					},
					"ls_http_frankfurter_properties_typeProperties_url": {
						"value": "[parameters('ls_http_frankfurter_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}