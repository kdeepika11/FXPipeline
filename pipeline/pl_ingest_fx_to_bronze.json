{
	"name": "pl_ingest_fx_to_bronze",
	"properties": {
		"activities": [
			{
				"name": "v_relative_url",
				"type": "SetVariable",
				"dependsOn": [],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "v_relative_url",
					"value": {
						"value": "@concat(pipeline().parameters.p_run_date,\n        '?from=', pipeline().parameters.p_base_ccy,\n        '&to=', pipeline().parameters.p_symbols)",
						"type": "Expression"
					}
				}
			},
			{
				"name": "v_target_folder",
				"type": "SetVariable",
				"dependsOn": [],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "v_target_folder",
					"value": {
						"value": "@concat('fx_rates/base=', pipeline().parameters.p_base_ccy,\n        '/run_date=', pipeline().parameters.p_run_date, '/')",
						"type": "Expression"
					}
				}
			},
			{
				"name": "v_target_file",
				"type": "SetVariable",
				"dependsOn": [],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "v_target_file",
					"value": {
						"value": "@concat('fx_rates_', pipeline().parameters.p_base_ccy, '_',\n        pipeline().parameters.p_run_date, '.json')",
						"type": "Expression"
					}
				}
			},
			{
				"name": "cp_http_to_bronze",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 3,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "JsonSource",
						"storeSettings": {
							"type": "HttpReadSettings",
							"requestMethod": "GET"
						},
						"formatSettings": {
							"type": "JsonReadSettings"
						}
					},
					"sink": {
						"type": "JsonSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "JsonWriteSettings"
						}
					},
					"enableStaging": false,
					"enableSkipIncompatibleRow": true,
					"logSettings": {
						"enableCopyActivityLog": true,
						"copyActivityLogSettings": {
							"logLevel": "Warning",
							"enableReliableLogging": false
						},
						"logLocationSettings": {
							"linkedServiceName": {
								"referenceName": "ls_adls_stassetlakehouse",
								"type": "LinkedServiceReference"
							}
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_http_fx",
						"type": "DatasetReference",
						"parameters": {
							"p_relative_url": {
								"value": "@variables('v_relative_url')",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "ds_adls_bronze_fx_json",
						"type": "DatasetReference",
						"parameters": {
							"p_folder": {
								"value": "@variables('v_target_folder')",
								"type": "Expression"
							},
							"p_file": {
								"value": "@variables('v_target_file')",
								"type": "Expression"
							},
							"p_container": "bronze"
						}
					}
				]
			}
		],
		"parameters": {
			"p_base_ccy": {
				"type": "string",
				"defaultValue": "USD"
			},
			"p_symbols": {
				"type": "string",
				"defaultValue": "EUR,GBP,JPY,CHF,CAD,AUD,USD"
			},
			"p_run_date": {
				"type": "string",
				"defaultValue": "@formatDateTime(addDays(utcNow(),-1),'yyyy-MM-dd')"
			}
		},
		"variables": {
			"v_relative_url": {
				"type": "String"
			},
			"v_target_folder": {
				"type": "String"
			},
			"v_target_file": {
				"type": "String"
			}
		},
		"annotations": [],
		"lastPublishTime": "2026-03-02T17:29:03Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}